{
  "name": "stellar-trust-escrow-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:test": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "eslint .",
    "analyze": "ANALYZE=true next build",
    "test": "npm run test:unit && npm run test:integration && npm run test:a11y",
    "test:unit": "jest --config jest.config.cjs --testPathIgnorePatterns='tests/(pages|a11y|integration|e2e)' --passWithNoTests",
    "test:integration": "jest --config jest.config.cjs --testPathPattern='tests/(pages|integration)' --passWithNoTests",
    "test:a11y": "jest --config jest.config.cjs --testPathPattern='tests/a11y' --passWithNoTests",
    "test:coverage": "jest --config jest.config.cjs --coverage --passWithNoTests",
    "test:e2e": "playwright test --config playwright.config.js",
    "test:e2e:ui": "playwright test --config playwright.config.js --ui",
    "test:visual:update": "PLAYWRIGHT_DISABLE_WEBSERVER=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000 playwright test --config playwright.config.js tests/e2e/visual.spec.js tests/e2e/navigation.spec.js tests/e2e/performance.spec.js --reporter=line --update-snapshots",
    "test:perf": "playwright test --config playwright.config.js tests/e2e/performance.spec.js --project=chromium",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@sentry/nextjs": "^9.5.0",
    "@stellar/freighter-api": "^2.0.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "@sumsub/websdk-react": "^2.6.1",
    "clsx": "^2.0.0",
    "lucide-react": "^0.383.0",
    "next": "^15.2.4",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.0",
    "swr": "^2.2.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^8.6.18",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "babel-jest": "^29.7.0",
    "cssstyle": "^6.2.0",
    "decimal.js": "^10.4.3",
    "eslint-config-next": "^16.2.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "safer-buffer": "^2.1.2",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.3.0",
    "tough-cookie": "^6.0.1",
    "typescript": "^5"
  }
}
