NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Multi-Currency ─────────────────────────────────────────────────────────────
# Exchange rate API endpoint (default: open.er-api.com — free, no key required)
NEXT_PUBLIC_EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
# How long to cache exchange rates in the browser (ms, default 1 hour)
NEXT_PUBLIC_FX_CACHE_TTL_MS=3600000

# ── Sentry Error Tracking ──────────────────────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_RELEASE=
# Server-only — used to upload source maps during build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
