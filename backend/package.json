{
  "name": "stellar-trust-escrow-backend",
  "version": "0.1.0",
  "description": "REST API and event indexer for StellarTrustEscrow",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "build": "echo 'No build step required for backend'",
    "start": "node server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest --runInBand",
    "test:chaos": "NODE_OPTIONS=--experimental-vm-modules npx jest --runInBand --testPathPattern=backend/tests/chaos --config=backend/jest.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "npx prisma migrate dev --schema=database/schema.prisma",
    "db:migrate:up": "node database/migrations/migrate.js up",
    "db:migrate:down": "node database/migrations/migrate.js down",
    "db:migrate:status": "node database/migrations/migrate.js status",
    "db:migrate:create": "node database/migrations/migrate.js create",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=database/schema.prisma",
    "db:generate": "npx prisma generate --schema=database/schema.prisma",
    "db:seed": "node database/seed/index.js",
    "db:seed:reset": "node database/seed/index.js --reset"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@prisma/client": "^5.0.0",
    "@sentry/node": "^8.55.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-stringify": "^6.7.0",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "forwarded": "^0.2.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "prom-client": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "supertest": "^6.3.4",
    "ws": "^8.20.0"
  }
}
