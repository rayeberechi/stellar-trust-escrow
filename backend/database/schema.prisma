// Prisma Schema — StellarTrustEscrow
//
// Run `npx prisma migrate dev` to create tables.
// Run `npx prisma generate` to regenerate the Prisma Client.
//
// TODO (contributor — medium, Issue #29):
// Review and finalize this schema. Consider:
// - Adding indexes for frequent query patterns (address lookups, status filters)
// - Adding created_at/updated_at to all tables (or using a Prisma plugin)
// - Whether dispute details need a separate table

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Escrows ───────────────────────────────────────────────────────────────────

model Escrow {
  /// On-chain escrow_id from the contract
  id                BigInt      @id
  clientAddress     String      @map("client_address")
  freelancerAddress String      @map("freelancer_address")
  arbiterAddress    String?     @map("arbiter_address")
  tokenAddress      String      @map("token_address")
  totalAmount       String      @map("total_amount")   // BigInt stored as string
  remainingBalance  String      @map("remaining_balance")
  status            EscrowStatus
  briefHash         String      @map("brief_hash")     // IPFS / content hash
  deadline          DateTime?
  createdAt         DateTime    @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  /// Stellar ledger sequence when this escrow was created
  createdLedger     BigInt      @map("created_ledger")

  milestones        Milestone[]
  dispute           Dispute?

  @@index([clientAddress])
  @@index([freelancerAddress])
  @@index([status])
  // Composite index for filtered + sorted list queries
  @@index([status, createdAt(sort: Desc)])
  @@map("escrows")
}

// ── Milestones ────────────────────────────────────────────────────────────────

model Milestone {
  id              Int             @id @default(autoincrement())
  /// on-chain milestone index within the escrow
  milestoneIndex  Int             @map("milestone_index")
  escrowId        BigInt          @map("escrow_id")
  title           String
  descriptionHash String          @map("description_hash")
  amount          String          // BigInt as string
  status          MilestoneStatus
  submittedAt     DateTime?       @map("submitted_at")
  resolvedAt      DateTime?       @map("resolved_at")

  escrow          Escrow          @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, milestoneIndex])
  @@index([escrowId])
  @@map("milestones")
}

// ── Reputation ────────────────────────────────────────────────────────────────

model ReputationRecord {
  address           String   @id
  totalScore        BigInt   @default(0) @map("total_score")
  completedEscrows  Int      @default(0) @map("completed_escrows")
  disputedEscrows   Int      @default(0) @map("disputed_escrows")
  disputesWon       Int      @default(0) @map("disputes_won")
  totalVolume       String   @default("0") @map("total_volume") // BigInt as string
  lastUpdated       DateTime @map("last_updated")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([totalScore(sort: Desc)])
  @@map("reputation_records")
}

// ── Disputes ─────────────────────────────────────────────────────────────────

model Dispute {
  id              Int       @id @default(autoincrement())
  escrowId        BigInt    @unique @map("escrow_id")
  raisedByAddress String    @map("raised_by_address")
  raisedAt        DateTime  @map("raised_at")
  resolvedAt      DateTime? @map("resolved_at")
  /// Amount returned to client on resolution
  clientAmount    String?   @map("client_amount")
  /// Amount sent to freelancer on resolution
  freelancerAmount String?  @map("freelancer_amount")
  /// Address that resolved the dispute (arbiter or admin)
  resolvedBy      String?   @map("resolved_by")
  /// Outcome description
  resolution      String?

  escrow          Escrow    @relation(fields: [escrowId], references: [id])

  @@index([raisedByAddress])
  @@map("disputes")
}

// ── Indexer State ─────────────────────────────────────────────────────────────

/// Tracks the last ledger processed so the indexer can resume after restart.
model IndexerState {
  id                  Int    @id @default(1)
  lastProcessedLedger BigInt @default(0) @map("last_processed_ledger")

  @@map("indexer_state")
}

// ── Admin Audit Log ───────────────────────────────────────────────────────────

/// Immutable record of every admin action for accountability and audit trails.
model AdminAuditLog {
  id              Int      @id @default(autoincrement())
  /// Action taken, e.g. SUSPEND_USER, BAN_USER, RESOLVE_DISPUTE
  action          String
  /// The address or resource the action was taken against
  targetAddress   String   @map("target_address")
  /// Human-readable reason supplied by the admin
  reason          String   @default("")
  /// Identifier of the admin who performed the action
  performedBy     String   @map("performed_by")
  performedAt     DateTime @map("performed_at")

  @@index([action])
  @@index([targetAddress])
  @@index([performedAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum EscrowStatus {
  Active
  Completed
  Disputed
  Cancelled
}

enum MilestoneStatus {
  Pending
  Submitted
  Approved
  Rejected
}
